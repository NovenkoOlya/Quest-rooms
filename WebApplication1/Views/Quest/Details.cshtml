@model WebApplication1.Models.Quest
@using WebApplication1.Models



<div class="container mt-4">
    <h2>@Model.Q_Name</h2>
    <p>@Model.Q_Description</p>
    @if (TempData["ReviewMessage"] != null)
    {
        <div class="alert alert-success">@TempData["ReviewMessage"]</div>
    }

    @if (User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value == "Client")
    {
        <form asp-controller="Review" asp-action="AddReview" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Room_ID" value="@Model.Room_ID" />

            <!-- Зірочки для рейтингу -->
            <div class="mb-3">
                <label class="form-label">Оцінка:</label>
                <div class="star-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <input type="radio" id="star-@i" name="Rating" value="@i" required />
                        <label for="star-@i">★</label>
                    }
                </div>
            </div>

            <!-- Текст відгуку -->
            <div class="mb-3">
                <textarea name="Review_Text" class="form-control" placeholder="Ваш відгук..." required></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Залишити відгук</button>
        </form>

        <!-- Кнопка бронювання -->
        <form asp-controller="Booking" asp-action="Create" method="get" class="mt-3">
            <input type="hidden" name="questId" value="@Model.Quest_ID" />
            <button type="submit" class="btn btn-success">Зробити бронювання</button>
        </form>
    }
    <h3>Відгуки</h3>

    @if (Model.Room != null && Model.Room.Review != null && Model.Room.Review.Any())
    {
        foreach (var review in Model.Room.Review.OrderByDescending(r => r.R_Creation_Date))
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@review.User.Full_Name</strong>
                    <span class="text-muted">
                        @(review.R_Creation_Date.HasValue
                            ? review.R_Creation_Date.Value.ToString("dd.MM.yyyy HH:mm")
                            : "")
                    </span>
                    <p>@review.Review_Text</p>
                    <p>Оцінка: @review.Rating ★</p>

                </div>
            </div>
        }
    }
    else
    {
        <p>Ще немає відгуків для цього квесту.</p>
    }


</div>
