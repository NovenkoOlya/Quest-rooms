@model IEnumerable<WebApplication1.Models.Quest>

@{
    ViewData["Title"] = "Список Квестів";
    var currentSort = ViewData["CurrentSort"] as string;
    var difficultyFilter = ViewData["DifficultyFilter"] as string;
    var minPrice = ViewData["MinPrice"];
    var maxPrice = ViewData["MaxPrice"];
    var difficulties = ViewBag.Difficulties as List<string>;
}

<h1 class="text-center text-dark fw-bold mb-4 pt-3">Обери свій квест‑виклик</h1>

<div class="row g-4 p-2">
    <aside class="col-lg-3">
        <div class="p-4 bg-white shadow rounded-3 sidebar-sticky">
            <h2 class="h5 fw-semibold text-secondary mb-3 border-bottom pb-2">Фільтрація та Сортування</h2>

            <form asp-controller="Quest" asp-action="Index" method="get">

                <!-- 1. Фільтр за складністю -->
                <div class="mb-3">
                    <label for="difficultyFilter" class="form-label fw-medium text-secondary">Складність:</label>
                    <select name="difficultyFilter" id="difficultyFilter" class="form-select border rounded-3">
                        <option value="all" selected="@(string.IsNullOrEmpty(difficultyFilter) || difficultyFilter == "all")">Усі рівні</option>
                        @if (difficulties != null)
                        {
                            @foreach (var diff in difficulties)
                            {
                                <option value="@diff" selected="@(difficultyFilter == diff)">@diff</option>
                            }
                        }
                    </select>
                </div>

                <!-- 2. Фільтр за ціною -->
                <div class="mb-3 border-top pt-3">
                    <h3 class="h6 fw-medium text-secondary mb-2">Діапазон Ціни:</h3>
                    <div class="d-flex gap-2">
                        <input type="number" name="minPrice" placeholder="Мінімум" value="@minPrice" class="form-control border rounded-3" />
                        <input type="number" name="maxPrice" placeholder="Максимум" value="@maxPrice" class="form-control border rounded-3" />
                    </div>
                </div>

                <!-- 3. Сортування -->
                <div class="mb-4 border-top pt-3">
                    <label for="sortOrder" class="form-label fw-medium text-secondary">Сортувати за:</label>
                    <select name="sortOrder" id="sortOrder" class="form-select border rounded-3">
                        <option value="default" selected="@(string.IsNullOrEmpty(currentSort) || currentSort == "default")">За замовчуванням</option>
                        <option value="price_desc" selected="@(currentSort == "price_desc")">Ціна: від більшої</option>
                        <option value="price_asc" selected="@(currentSort == "price_asc")">Ціна: від меншої</option>
                        <option value="difficulty_desc" selected="@(currentSort == "difficulty_desc")">Складність: від найвищої</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-hostel w-100 p-2 fw-semibold">Застосувати</button>
                <a asp-controller="Quest" asp-action="Index" class="d-block mt-2 w-100 text-center text-sm text-secondary text-decoration-none">Скинути</a>
            </form>
        </div>
    </aside>

    <main class="col-lg-9">
        @if (!Model.Any())
        {
            <div class="text-center p-5 bg-white shadow rounded-3 text-secondary">
                <p class="h4">На жаль, за вашими критеріями квестів не знайдено.</p>
                <a asp-controller="Quest" asp-action="Index" class="mt-3 btn btn-outline-hostel">Показати всі квести</a>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                @foreach (var quest in Model)
                {
                    <div class="col">
                        <div class="card shadow-sm h-100">
                            <div class="position-relative" style="height: 180px; background-color: #f8f9fa;">
                                <img src="https://placehold.co/400x180/e9ecef/495057?text=@quest.Q_Name"
                                     class="card-img-top h-100 object-fit-cover"
                                     alt="Зображення квесту @quest.Q_Name" />                            
                            </div>

                            <div class="card-body p-4">
                                <h3 class="h5 fw-bold text-dark mb-1">@quest.Q_Name</h3>
                                <div class="text-sm text-secondary mb-3">Складність: @quest.Difficulty_Level</div>
                                <p class="h4 fw-semibold text-success mb-1">@quest.Base_Price ₴</p>
                                <p class="text-muted">@quest.Q_Description</p>

                                <div class="mt-3">
                                    <a asp-controller="Quest" asp-action="Details" asp-route-id="@quest.Room_ID"
                                       class="btn btn-hostel w-100 fw-semibold">Детальніше</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </main>
</div>
