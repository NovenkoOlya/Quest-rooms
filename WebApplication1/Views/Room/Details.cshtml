@model WebApplication1.Models.Room

<h2>@Model.QR_Name</h2>
<p>@Model.QR_Description</p>
<p>@Model.City, @Model.Address</p>
<p>Контакти: @Model.Contact_Info</p>
<p>Статус: @(Model.Availability_Status ? "Підтверджено" : "Очікує / Відхилено")</p>

<h3>Квести</h3>
<ul>
@foreach (var quest in Model.Quests)
{
    <li><a asp-controller="Quest" asp-action="Details" asp-route-id="@quest.Quest_ID">@quest.Q_Name</a></li>
}
</ul>

<h3>Відгуки</h3>
<ul>
@foreach (var review in Model.Review)
{
    <li>@review.Rating/5 — @review.Review_Text</li>
}
</ul>
